{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/sijosa.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/sijosa",
      "dest": "/api/sijosa.js"
    },
    {
      "src": "/api/chapters",
      "dest": "/api/chapters.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
